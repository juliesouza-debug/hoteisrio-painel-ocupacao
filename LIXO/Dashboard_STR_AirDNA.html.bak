<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Dashboard STR — AirDNA · Rio de Janeiro</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#0f1117;color:#e2e8f0;min-height:100vh}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#1a1d27}
::-webkit-scrollbar-thumb{background:#2d3148;border-radius:3px}
.header{background:#131620;border-bottom:1px solid #1e2235;padding:14px 24px;display:flex;align-items:center;gap:16px}
.logo{font-size:18px;font-weight:700;color:#fff;letter-spacing:-0.5px}
.logo span{color:#2563eb}
.subtitle{font-size:12px;color:#64748b;margin-left:auto}
.filter-bar{background:#131620cc;border-bottom:1px solid #1e2235;padding:10px 24px;display:flex;flex-wrap:wrap;align-items:center;gap:10px;position:sticky;top:0;z-index:100}
.filter-group{display:flex;align-items:center;gap:6px}
.filter-label{font-size:11px;color:#64748b;white-space:nowrap}
select{background:#1e2235;border:1px solid #2d3148;color:#e2e8f0;padding:5px 8px;border-radius:6px;font-size:12px;cursor:pointer;outline:none}
select:hover{border-color:#3d4560}
.presets{display:flex;flex-wrap:wrap;gap:5px;margin-left:4px}
.chip{background:#1e2235;border:1px solid #2d3148;color:#94a3b8;padding:4px 10px;border-radius:20px;font-size:11px;cursor:pointer;transition:all .15s;white-space:nowrap}
.chip:hover{border-color:#3d4560;color:#e2e8f0}
.chip.active{background:#2563eb22;border-color:#2563eb;color:#60a5fa}
.gran-toggle{display:flex;border:1px solid #2d3148;border-radius:6px;overflow:hidden;margin-left:auto}
.region-bar{display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:14px;padding:8px 12px;background:#131620;border:1px solid #1e2235;border-radius:8px}
.region-bar-title{font-size:11px;color:#64748b;white-space:nowrap;margin-right:2px}
.gran-btn{background:#1e2235;color:#94a3b8;padding:5px 14px;font-size:12px;cursor:pointer;border:none;transition:all .15s}
.gran-btn:hover{color:#e2e8f0}
.gran-btn.active{background:#2563eb;color:#fff}
.tabs-bar{background:#0f1117;border-bottom:1px solid #1e2235;padding:0 24px;display:flex;gap:0;overflow-x:auto}
.tab-btn{color:#64748b;padding:12px 18px;font-size:13px;cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.tab-btn:hover{color:#e2e8f0}
.tab-btn.active{color:#60a5fa;border-bottom-color:#2563eb}
.content{padding:20px 24px;max-width:1600px;margin:0 auto}
.tab-pane{display:none}
.tab-pane.active{display:block}
.section-header{display:flex;align-items:center;gap:10px;margin-bottom:16px}
.section-title{font-size:16px;font-weight:600;color:#e2e8f0}
.badge{font-size:10px;padding:2px 8px;border-radius:10px;font-weight:600;background:#2563eb22;color:#60a5fa;border:1px solid #2563eb44}
.kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px}
.kpi-card{background:#1a1d27;border:1px solid #1e2235;border-radius:10px;padding:14px 16px}
.kpi-label{font-size:11px;color:#64748b;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
.kpi-value{font-size:22px;font-weight:700;color:#e2e8f0;letter-spacing:-0.5px}
.kpi-delta{font-size:11px;margin-top:4px}
.kpi-delta.pos{color:#10b981}
.kpi-delta.neg{color:#ef4444}
.kpi-delta.neu{color:#64748b}
.charts-grid{display:grid;gap:16px;margin-bottom:16px}
.chart-card{background:#1a1d27;border:1px solid #1e2235;border-radius:10px;padding:16px}
.chart-title{font-size:13px;font-weight:600;color:#94a3b8;margin-bottom:14px}
.chart-wrap{position:relative;height:260px}
.chart-wrap.tall{height:320px}
.yoy-section{margin-bottom:28px}
.yoy-title{font-size:13px;font-weight:600;color:#94a3b8;margin-bottom:10px}
.tbl-wrap{overflow-x:auto;border-radius:8px;border:1px solid #1e2235}
table{width:100%;border-collapse:collapse;font-size:12px}
th{background:#1e2235;color:#64748b;padding:8px 10px;text-align:right;font-weight:600;letter-spacing:.3px;white-space:nowrap}
th:first-child{text-align:left}
td{padding:7px 10px;text-align:right;border-top:1px solid #1a1d2755;white-space:nowrap}
td:first-child{text-align:left;color:#94a3b8}
tr:hover td{background:#1e223530}
.dp{color:#10b981;font-weight:600}
.dn{color:#ef4444;font-weight:600}
.dn0{color:#64748b}
</style>
</head>
<body>

<div class="header">
  <div class="logo">STR<span>Analytics</span></div>
  <div style="font-size:12px;color:#64748b">Rio de Janeiro · Dados AirDNA</div>
  <div class="subtitle">mai/2023 – abr/2026</div>
</div>

<div class="filter-bar">
  <div class="filter-group">
    <span class="filter-label">De</span>
    <select id="selStart"></select>
    <span class="filter-label">Até</span>
    <select id="selEnd"></select>
  </div>
  <div class="presets" id="presetsBar"></div>
  <div class="gran-toggle">
    <button class="gran-btn active" data-g="mensal">Mensal</button>
    <button class="gran-btn" data-g="anual">Anual</button>
  </div>
</div>

<div class="tabs-bar">
  <button class="tab-btn active" data-tab="overview">Visão Geral</button>
  <button class="tab-btn" data-tab="listings">Anúncios</button>
  <button class="tab-btn" data-tab="occupancy">Ocupação</button>
  <button class="tab-btn" data-tab="revenue">Receita</button>
  <button class="tab-btn" data-tab="rates">Tarifas</button>
  <button class="tab-btn" data-tab="seasonality">Sazonalidade</button>
</div>

<div class="content">

  <!-- VISÃO GERAL -->
  <div class="tab-pane active" id="tab-overview">
    <div class="kpi-row" id="kpi-overview"></div>
    <div class="charts-grid" style="grid-template-columns:2fr 1fr">
      <div class="chart-card">
        <div class="chart-title">RevPAR & Taxa de Ocupação — Rio de Janeiro</div>
        <div class="chart-wrap tall"><canvas id="ch-overview-main"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Demanda (Listing-dias Reservados)</div>
        <div class="chart-wrap tall"><canvas id="ch-overview-demand"></canvas></div>
      </div>
    </div>
  </div>

  <!-- ANÚNCIOS -->
  <div class="tab-pane" id="tab-listings">
    <div class="kpi-row" id="kpi-listings"></div>
    <div class="charts-grid" style="grid-template-columns:1fr 1fr">
      <div class="chart-card">
        <div class="chart-title">Anúncios Reservados</div>
        <div class="chart-wrap"><canvas id="ch-lst-trend"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Anúncios por Número de Quartos</div>
        <div class="chart-wrap"><canvas id="ch-lst-bed"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Tempo Médio de Estadia (noites)</div>
        <div class="chart-wrap"><canvas id="ch-lst-los"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Janelas de Antecedência da Reserva — mai/25–abr/26</div>
        <div class="chart-wrap"><canvas id="ch-lst-adv"></canvas></div>
      </div>
    </div>
  </div>

  <!-- OCUPAÇÃO -->
  <div class="tab-pane" id="tab-occupancy">
    <div class="region-bar"><span class="region-bar-title">Região:</span><div id="region-bar-occ" style="display:flex;flex-wrap:wrap;gap:6px"></div></div>
    <div class="kpi-row" id="kpi-occupancy"></div>
    <div class="charts-grid" style="grid-template-columns:2fr 1fr">
      <div class="chart-card">
        <div class="chart-title">Taxa de Ocupação — Rio de Janeiro</div>
        <div class="chart-wrap tall"><canvas id="ch-occ-trend"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Pace de Reservas — Próximos 30 dias (a partir de 14/mai/26)</div>
        <div class="chart-wrap tall"><canvas id="ch-occ-future"></canvas></div>
      </div>
    </div>
    <div class="charts-grid" style="grid-template-columns:2fr 1fr">
      <div class="chart-card">
        <div class="chart-title">Comparativo de Ocupação — Hotelaria Formal vs STR (mensal)</div>
        <div class="chart-wrap tall"><canvas id="ch-occ-comp"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Ocupação Anual Média — Hotelaria vs STR</div>
        <div class="chart-wrap tall"><canvas id="ch-occ-annual"></canvas></div>
      </div>
    </div>
  </div>

  <!-- RECEITA -->
  <div class="tab-pane" id="tab-revenue">
    <div class="section-header">
      <span class="section-title">Receita</span>
      <span class="badge">📍 Copacabana</span>
    </div>
    <div class="kpi-row" id="kpi-revenue"></div>
    <div class="charts-grid" style="grid-template-columns:1fr 1fr">
      <div class="chart-card">
        <div class="chart-title">Receita Média Mensal</div>
        <div class="chart-wrap"><canvas id="ch-rev-avg"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Receita por Número de Quartos</div>
        <div class="chart-wrap"><canvas id="ch-rev-bed"></canvas></div>
      </div>
      <div class="chart-card" style="grid-column:1/-1">
        <div class="chart-title">Distribuição por Percentil (P25 / P50 / P75 / P90)</div>
        <div class="chart-wrap"><canvas id="ch-rev-pct"></canvas></div>
      </div>
    </div>
  </div>

  <!-- TARIFAS -->
  <div class="tab-pane" id="tab-rates">
    <div class="section-header">
      <span class="section-title">Tarifas</span>
      <span class="badge">📍 Copacabana</span>
    </div>
    <div class="kpi-row" id="kpi-rates"></div>
    <div class="charts-grid" style="grid-template-columns:1fr 1fr">
      <div class="chart-card">
        <div class="chart-title">Tarifa Diária Média Mensal</div>
        <div class="chart-wrap"><canvas id="ch-rate-avg"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Tarifa por Faixa de Preço</div>
        <div class="chart-wrap"><canvas id="ch-rate-tier"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Tarifa por Número de Quartos</div>
        <div class="chart-wrap"><canvas id="ch-rate-bed"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Tarifa Diária Histórica — jun/25 a mai/26</div>
        <div class="chart-wrap"><canvas id="ch-rate-daily"></canvas></div>
      </div>
      <div class="chart-card" style="grid-column:1/-1">
        <div class="chart-title">Previsão de Tarifa & Anúncios Reservados — mai a out/26</div>
        <div class="chart-wrap"><canvas id="ch-rate-future"></canvas></div>
      </div>
    </div>
  </div>

  <!-- SAZONALIDADE -->
  <div class="tab-pane" id="tab-seasonality">
    <div class="section-header">
      <span class="section-title">Comparativo Ano a Ano</span>
    </div>
    <div class="yoy-section">
      <div class="yoy-title">Ocupação (%)</div>
      <div class="tbl-wrap"><table id="tbl-occ"></table></div>
    </div>
    <div class="yoy-section">
      <div class="yoy-title">RevPAR — Rio de Janeiro (R$)</div>
      <div class="tbl-wrap"><table id="tbl-rev"></table></div>
    </div>
    <div class="yoy-section">
      <div class="yoy-title">Receita Média — Copacabana (R$)</div>
      <div class="tbl-wrap"><table id="tbl-coprev"></table></div>
    </div>
    <div class="yoy-section">
      <div class="yoy-title">Tarifa Diária Média — Copacabana (R$)</div>
      <div class="tbl-wrap"><table id="tbl-coprate"></table></div>
    </div>
    <div class="section-header" style="margin-top:28px">
      <span class="section-title">Hotelaria Formal vs STR</span>
      <span class="badge" style="background:#10b98122;color:#10b981;border-color:#10b98144">Fonte: HotéisRIO</span>
    </div>
    <div class="region-bar"><span class="region-bar-title">Região:</span><div id="region-bar-sea" style="display:flex;flex-wrap:wrap;gap:6px"></div></div>
    <div class="yoy-section">
      <div class="yoy-title" id="tbl-hotelvsstr-title">Comparativo de Ocupação — Hotelaria Formal (%) vs STR AirDNA (%)</div>
      <div class="tbl-wrap"><table id="tbl-hotelvsstr"></table></div>
    </div>
  </div>

</div>

<script>
// ══════════════════ DATA ══════════════════
const monthlyKeys=["2023-05","2023-06","2023-07","2023-08","2023-09","2023-10","2023-11","2023-12","2024-01","2024-02","2024-03","2024-04","2024-05","2024-06","2024-07","2024-08","2024-09","2024-10","2024-11","2024-12","2025-01","2025-02","2025-03","2025-04","2025-05","2025-06","2025-07","2025-08","2025-09","2025-10","2025-11","2025-12","2026-01","2026-02","2026-03","2026-04"];
