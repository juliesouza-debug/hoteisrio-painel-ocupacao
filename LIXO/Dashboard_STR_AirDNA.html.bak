// Advance booking windows (12 months fixed)
const advKeys=["2025-05","2025-06","2025-07","2025-08","2025-09","2025-10","2025-11","2025-12","2026-01","2026-02","2026-03","2026-04"];
const adv06=[25955,24219,30246,29392,29736,31663,30133,29551,38191,31718,38806,35500];
const adv714=[10349,9558,11155,11331,12004,13317,12339,11888,15398,12054,14661,14662];
const adv1530=[12594,12568,12347,13470,14979,16174,16148,15306,19010,19487,17813,18799];
const adv3160=[12596,11824,10769,11358,12291,14411,16838,15902,19135,22899,17696,17815];
const adv6190=[9143,5946,5115,5160,4988,6000,8333,10964,10103,14008,7790,10109];
const adv91p=[13095,9462,6529,7180,6589,6997,10569,22605,16145,27605,8261,10345];

// ══════════════════ STATE ══════════════════
const SEASON_MONTHS={alta:[12,1,2],baixa:[5,6]};
let state={gran:'mensal',startMonth:'2023-05',endMonth:'2026-04',season:null,activePreset:'all'};
let activeRegion='cidade';
const REGIONS={
  cidade:{label:'Rio de Janeiro (Cidade)',str:mOcc,hotel:hOcc},
  copa:{label:'Leme / Copacabana',str:strCopa,hotel:hCopa},
  ipanema:{label:'Ipanema / Leblon',str:strIpanema,hotel:hIpanema},
  flamengo:{label:'Flamengo / Botafogo',str:strFlamengo,hotel:hFlamengo},
  barra:{label:'Barra da Tijuca / Recreio',str:strBarra,hotel:hBarra},
  centro:{label:'Centro',str:strCentro,hotel:hCentro},
};
const PRESETS={
  all:{start:'2023-05',end:'2026-04',season:null,label:'Todos 36m'},
  y2023:{start:'2023-05',end:'2023-12',season:null,label:'2023'},
  y2024:{start:'2024-01',end:'2024-12',season:null,label:'2024'},
  y2025:{start:'2025-01',end:'2025-12',season:null,label:'2025'},
  y2026:{start:'2026-01',end:'2026-04',season:null,label:'2026'},
  l12m:{start:'2025-05',end:'2026-04',season:null,label:'Últimos 12m'},
  ytd26:{start:'2026-01',end:'2026-04',season:null,label:'YTD 2026'},
  carnaval:{start:'2025-02',end:'2025-02',season:null,label:'Carnaval Fev/25'},
  alta:{start:'2023-05',end:'2026-04',season:'alta',label:'Alta Temp (Dez-Fev)'},
  baixa:{start:'2023-05',end:'2026-04',season:'baixa',label:'Baixa Temp (Mai-Jun)'},
};

// ══════════════════ HELPERS ══════════════════
const MNAMES_PT=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
function fmtM(k){const[y,m]=k.split('-');return MNAMES_PT[+m-1]+'/'+y.slice(2);}
function fmtBRL(v,dec=0){if(v==null||isNaN(v))return'–';return'R$ '+v.toLocaleString('pt-BR',{minimumFractionDigits:dec,maximumFractionDigits:dec});}
function fmtPct(v){if(v==null||isNaN(v))return'–';return v.toFixed(1).replace('.',',')+'%';}
function fmtNum(v){return v==null?'–':v.toLocaleString('pt-BR');}
function avg(arr){const a=arr.filter(x=>x!=null&&!isNaN(x));return a.length?a.reduce((s,x)=>s+x,0)/a.length:null;}
function sum(arr){return arr.filter(x=>x!=null&&!isNaN(x)).reduce((s,x)=>s+x,0);}
function monthPasses(k){
  if(k<state.startMonth||k>state.endMonth)return false;
  if(state.season){const m=+k.split('-')[1];return SEASON_MONTHS[state.season].includes(m);}
  return true;
}
function getIdxs(){return monthlyKeys.reduce((a,k,i)=>{if(monthPasses(k))a.push(i);return a;},[]); }
function aggAnnual(vals,idxs,useSum=false){
  const map={};
  idxs.forEach(i=>{
    const y=monthlyKeys[i].split('-')[0];
    if(!map[y])map[y]=[];
    if(vals[i]!=null)map[y].push(vals[i]);
  });
  const yrs=Object.keys(map).sort();
  return{labels:yrs,data:yrs.map(y=>useSum?sum(map[y]):avg(map[y]))};
}
function getCD(vals,idxs,useSum=false){
  if(state.gran==='anual'){const r=aggAnnual(vals,idxs,useSum);return r;}
  return{labels:idxs.map(i=>fmtM(monthlyKeys[i])),data:idxs.map(i=>vals[i])};
}
function deltaClass(v){return v>0?'pos':v<0?'neg':'neu';}
function deltaPct(a,b){if(a==null||b==null||a===0)return null;return((b-a)/Math.abs(a))*100;}

// ══════════════════ CHART SETUP ══════════════════
const C=['#2563eb','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316'];
Chart.defaults.color='#64748b';
Chart.defaults.borderColor='rgba(255,255,255,0.07)';
Chart.defaults.font={family:'Segoe UI,system-ui,sans-serif',size:11};
const TTP={backgroundColor:'#1e2235',borderColor:'#2d3148',borderWidth:1,titleColor:'#e2e8f0',bodyColor:'#94a3b8',padding:10,cornerRadius:6};
const GRD={color:'rgba(255,255,255,0.05)'};
const TCK={color:'#64748b'};
function ax(opts={}){return{grid:GRD,ticks:{...TCK,...(opts.ticks||{})},title:{color:'#64748b',...(opts.title||{})},...opts};}
function lineDS(label,data,color,fill=false,yAxis='y'){
  return{label,data,borderColor:color,backgroundColor:fill?color+'22':'transparent',fill,tension:0.4,pointRadius:2,pointHoverRadius:5,borderWidth:2,yAxisID:yAxis};
}
function barDS(label,data,color){
  return{label,data,backgroundColor:color+'cc',borderColor:color,borderWidth:1,borderRadius:3,yAxisID:'y'};
}
const charts={};
function mkChart(id,cfg){
  const el=document.getElementById(id);
  if(!el)return null;
  if(charts[id])charts[id].destroy();
  charts[id]=new Chart(el,cfg);
  return charts[id];
}

// ══════════════════ KPI ══════════════════
function setKPIs(id,items){
  const el=document.getElementById(id);
  if(!el)return;
  el.innerHTML=items.map(k=>`<div class="kpi-card"><div class="kpi-label">${k.label}</div><div class="kpi-value">${k.value}</div>${k.sub!=null?`<div class="kpi-delta ${k.cls||'neu'}">${k.sub}</div>`:''}</div>`).join('');
}

// ══════════════════ RENDER FUNCTIONS ══════════════════

function renderOverview(){
  const idxs=getIdxs(); if(!idxs.length)return;
  const li=idxs[idxs.length-1], pi=idxs.length>1?idxs[idxs.length-2]:null;
  const d1=pi!=null?deltaPct(mOcc[pi],mOcc[li]):null;
  const d2=pi!=null?deltaPct(mRev[pi],mRev[li]):null;
  const d3=pi!=null?deltaPct(copRevAvg[pi],copRevAvg[li]):null;
  const d4=pi!=null?deltaPct(copRateAvg[pi],copRateAvg[li]):null;
  const fmtD=d=>d==null?'–':(d>=0?'+':'')+d.toFixed(1)+'% vs anterior';
  setKPIs('kpi-overview',[
    {label:'Ocupação (último)',value:fmtPct(mOcc[li]),sub:fmtD(d1),cls:deltaClass(d1||0)},
    {label:'RevPAR (último)',value:fmtBRL(mRev[li],2),sub:fmtD(d2),cls:deltaClass(d2||0)},
    {label:'Receita Média · Copa',value:fmtBRL(copRevAvg[li],0),sub:fmtD(d3),cls:deltaClass(d3||0)},
    {label:'Tarifa Diária · Copa',value:fmtBRL(copRateAvg[li],0),sub:fmtD(d4),cls:deltaClass(d4||0)},
    {label:'Média Ocupação',value:fmtPct(avg(idxs.map(i=>mOcc[i]))),sub:'período selecionado'},
    {label:'Média RevPAR',value:fmtBRL(avg(idxs.map(i=>mRev[i])),2),sub:'período selecionado'},
  ]);
  const rD=getCD(mRev,idxs), oD=getCD(mOcc,idxs);
  mkChart('ch-overview-main',{type:'line',data:{labels:rD.labels,datasets:[
    lineDS('RevPAR (R$)',rD.data,C[0],true),
    lineDS('Ocupação (%)',oD.data,C[1],false,'y1'),
  ]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.yAxisID==='y1'?'Ocup.: '+fmtPct(ctx.raw):'RevPAR: '+fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{
    x:ax({ticks:{maxRotation:45}}),
    y:{...ax(),position:'left',title:{display:true,text:'RevPAR (R$)',color:'#64748b'}},
    y1:{...ax(),position:'right',grid:{drawOnChartArea:false},max:100,title:{display:true,text:'Ocupação (%)',color:'#64748b'},ticks:{...TCK,callback:v=>v+'%'}},
  }}});
  const dD=getCD(mDem,idxs,true);
  mkChart('ch-overview-demand',{type:'bar',data:{labels:dD.labels,datasets:[barDS('Listing-dias Reservados',dD.data,C[2])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>'Demanda: '+fmtNum(ctx.raw)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
}

function renderListings(){
  const idxs=getIdxs(); if(!idxs.length)return;
  const li=idxs[idxs.length-1];
  const losValid=idxs.filter(i=>mLos[i]!=null);
  const losLast=mLos[li];
  setKPIs('kpi-listings',[
    {label:'Anúncios Reservados (último)',value:fmtNum(mLst[li]),sub:''},
    {label:'Média do Período',value:fmtNum(Math.round(avg(idxs.map(i=>mLst[i])))),sub:'anúncios/mês'},
    {label:'Permanência Média',value:losLast!=null?losLast.toFixed(2)+' noites':'N/D',sub:'último mês disponível'},
    {label:'Demanda Total',value:fmtNum(sum(idxs.map(i=>mDem[i]))),sub:'listing-dias reservados'},
  ]);
  const lstD=getCD(mLst,idxs);
  mkChart('ch-lst-trend',{type:'line',data:{labels:lstD.labels,datasets:[lineDS('Anúncios Reservados',lstD.data,C[0],true)]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>'Anúncios: '+fmtNum(ctx.raw)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
  const b1=getCD(mBed1,idxs),b2=getCD(mBed2,idxs),b3=getCD(mBed3,idxs),b4=getCD(mBed4,idxs);
  mkChart('ch-lst-bed',{type:'bar',data:{labels:b1.labels,datasets:[barDS('1 Quarto',b1.data,C[0]),barDS('2 Quartos',b2.data,C[1]),barDS('3 Quartos',b3.data,C[2]),barDS('4+ Quartos',b4.data,C[3])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:{...ax({ticks:{maxRotation:45}}),stacked:true},y:{...ax(),stacked:true}}}});
  if(losValid.length>0){
    const losD=getCD(mLos,losValid);
    mkChart('ch-lst-los',{type:'line',data:{labels:losD.labels,datasets:[lineDS('Permanência (noites)',losD.data,C[4],true)]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.raw!=null?ctx.raw.toFixed(2)+' noites':'–'}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:{...ax(),suggestedMin:4,suggestedMax:8}}}});
  }
  const advLbls=advKeys.map(fmtM);
  mkChart('ch-lst-adv',{type:'bar',data:{labels:advLbls,datasets:[barDS('0–6 dias',adv06,C[0]),barDS('7–14 dias',adv714,C[1]),barDS('15–30 dias',adv1530,C[2]),barDS('31–60 dias',adv3160,C[3]),barDS('61–90 dias',adv6190,C[4]),barDS('91+ dias',adv91p,C[5])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:{...ax({ticks:{maxRotation:45}}),stacked:true},y:{...ax(),stacked:true}}}});
}

function renderOccupancy(){
  const idxs=getIdxs(); if(!idxs.length)return;
  const li=idxs[idxs.length-1];
  const reg=REGIONS[activeRegion];
  const strData=reg.str, hotelData=reg.hotel;
  const occVals=idxs.map(i=>strData[i]).filter(v=>v!=null);
  const maxV=Math.max(...occVals), minV=Math.min(...occVals);
  const peakI=idxs[idxs.map(i=>strData[i]).indexOf(maxV)];
  setKPIs('kpi-occupancy',[
    {label:'Ocupação STR (último mês)',value:fmtPct(strData[li]),sub:reg.label},
    {label:'Média do Período',value:fmtPct(avg(idxs.map(i=>strData[i]))),sub:''},
    {label:'Pico do Período',value:fmtPct(maxV),sub:peakI!=null?fmtM(monthlyKeys[peakI]):''},
    {label:'Mínimo do Período',value:fmtPct(minV),sub:''},
  ]);
  const oD=getCD(strData,idxs);
  mkChart('ch-occ-trend',{type:'line',data:{labels:oD.labels,datasets:[lineDS('Ocupação STR (%)',oD.data,C[0],true)]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>fmtPct(ctx.raw)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:{...ax(),max:100,ticks:{...TCK,callback:v=>v+'%'}}}}});
  // Pace de reservas (sempre cidade, dados AirDNA globais)
  const futLbls=futOccDates.map(d=>{const[,m,day]=d.split('-');return MNAMES_PT[+m-1]+'/'+day;});
  mkChart('ch-occ-future',{type:'bar',data:{labels:futLbls,datasets:[barDS('Últ. 30 dias',futOccLast30,C[2]),barDS('Últ. 7 dias',futOccLast7,C[0])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45,maxTicksLimit:15}}),y:ax()}}});

  // ── Comparativo Hotelaria vs STR ──────────────────────────
  const allIdxs=monthlyKeys.map((_,i)=>i);
  const validHIdxs=allIdxs.filter(i=>hotelData[i]!=null);
  if(state.gran==='anual'){
    const hAnn=aggAnnual(hotelData,validHIdxs);
    const sAnn=aggAnnual(strData,idxs);
    const allYrs=[...new Set([...hAnn.labels,...sAnn.labels])].sort();
    const hVals=allYrs.map(y=>{const i=hAnn.labels.indexOf(y);return i>=0?hAnn.data[i]:null;});
    const sVals=allYrs.map(y=>{const i=sAnn.labels.indexOf(y);return i>=0?sAnn.data[i]:null;});
    mkChart('ch-occ-comp',{type:'bar',data:{labels:allYrs,datasets:[
      {label:'Hotelaria Formal',data:hVals,backgroundColor:'#10b98188',borderColor:'#10b981',borderWidth:1,borderRadius:3},
      {label:'STR (AirDNA)',data:sVals,backgroundColor:C[0]+'88',borderColor:C[0],borderWidth:1,borderRadius:3},
    ]},options:{responsive:true,maintainAspectRatio:false,
      plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtPct(ctx.raw)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},
      scales:{x:ax(),y:{...ax(),max:100,ticks:{...TCK,callback:v=>v+'%'}}}}});
  } else {
    const compLabels=idxs.map(i=>fmtM(monthlyKeys[i]));
    mkChart('ch-occ-comp',{type:'line',data:{labels:compLabels,datasets:[
      lineDS('Hotelaria Formal (HotéisRIO)',idxs.map(i=>hotelData[i]),'#10b981',false),
      lineDS('STR (AirDNA)',idxs.map(i=>strData[i]),C[0],false),
    ]},options:{responsive:true,maintainAspectRatio:false,
      plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtPct(ctx.raw)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},
      scales:{x:ax({ticks:{maxRotation:45}}),y:{...ax(),max:100,ticks:{...TCK,callback:v=>v+'%'}}}}});
  }

  // ── Barras anuais — todos os anos disponíveis ──────────────
  const hAnnAll=aggAnnual(hotelData,validHIdxs);
  const sAnnAll=aggAnnual(strData,allIdxs);
  const allYrs2=[...new Set([...hAnnAll.labels,...sAnnAll.labels])].sort();
  mkChart('ch-occ-annual',{type:'bar',data:{labels:allYrs2,datasets:[
    {label:'Hotelaria Formal',data:allYrs2.map(y=>{const i=hAnnAll.labels.indexOf(y);return i>=0?hAnnAll.data[i]:null;}),backgroundColor:'#10b98188',borderColor:'#10b981',borderWidth:1,borderRadius:3},
    {label:'STR (AirDNA)',data:allYrs2.map(y=>{const i=sAnnAll.labels.indexOf(y);return i>=0?sAnnAll.data[i]:null;}),backgroundColor:C[0]+'88',borderColor:C[0],borderWidth:1,borderRadius:3},
  ]},options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtPct(ctx.raw)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},
    scales:{x:ax(),y:{...ax(),max:100,ticks:{...TCK,callback:v=>v+'%'}}}
  }});
}

function renderRevenue(){
  const idxs=getIdxs(); if(!idxs.length)return;
  const li=idxs[idxs.length-1];
  const lk=monthlyKeys[li];
  const lyI=monthlyKeys.indexOf((+lk.split('-')[0]-1)+'-'+lk.split('-')[1]);
  const delta=lyI>=0?deltaPct(copRevAvg[lyI],copRevAvg[li]):null;
  setKPIs('kpi-revenue',[
    {label:'Receita Média (último mês)',value:fmtBRL(copRevAvg[li],0),sub:''},
    {label:'vs. mesmo mês ano ant.',value:delta!=null?(delta>=0?'+':'')+delta.toFixed(1)+'%':'–',cls:delta!=null?deltaClass(delta):'neu',sub:''},
    {label:'Média do Período',value:fmtBRL(avg(idxs.map(i=>copRevAvg[i])),0),sub:''},
    {label:'Mediana P50 (último)',value:fmtBRL(copRevP50[li],0),sub:''},
  ]);
  const rD=getCD(copRevAvg,idxs);
  mkChart('ch-rev-avg',{type:'line',data:{labels:rD.labels,datasets:[lineDS('Receita Média (R$)',rD.data,C[0],true)]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
  const rb1=getCD(copRevB1,idxs),rb2=getCD(copRevB2,idxs),rb3=getCD(copRevB3,idxs),rb4=getCD(copRevB4,idxs);
  mkChart('ch-rev-bed',{type:'line',data:{labels:rb1.labels,datasets:[lineDS('1 Quarto',rb1.data,C[0]),lineDS('2 Quartos',rb2.data,C[1]),lineDS('3 Quartos',rb3.data,C[2]),lineDS('4 Quartos',rb4.data,C[3])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
  const p25D=getCD(copRevP25,idxs),p50D=getCD(copRevP50,idxs),p75D=getCD(copRevP75,idxs),p90D=getCD(copRevP90,idxs);
  mkChart('ch-rev-pct',{type:'line',data:{labels:p25D.labels,datasets:[lineDS('P90',p90D.data,C[3]),lineDS('P75',p75D.data,C[2]),lineDS('P50 (mediana)',p50D.data,C[0],true),lineDS('P25',p25D.data,C[1])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
}

function renderRates(){
  const idxs=getIdxs(); if(!idxs.length)return;
  const li=idxs[idxs.length-1];
  const lk=monthlyKeys[li];
  const lyI=monthlyKeys.indexOf((+lk.split('-')[0]-1)+'-'+lk.split('-')[1]);
  const delta=lyI>=0?deltaPct(copRateAvg[lyI],copRateAvg[li]):null;
  setKPIs('kpi-rates',[
    {label:'Tarifa Diária Média (último)',value:fmtBRL(copRateAvg[li],0),sub:''},
    {label:'vs. mesmo mês ano ant.',value:delta!=null?(delta>=0?'+':'')+delta.toFixed(1)+'%':'–',cls:delta!=null?deltaClass(delta):'neu',sub:''},
    {label:'Média do Período',value:fmtBRL(avg(idxs.map(i=>copRateAvg[i])),0),sub:''},
    {label:'Tarifa Luxury (último)',value:fmtBRL(copRateLuxury[li],0),sub:''},
  ]);
  const rD=getCD(copRateAvg,idxs);
  mkChart('ch-rate-avg',{type:'line',data:{labels:rD.labels,datasets:[lineDS('Tarifa Média (R$)',rD.data,C[0],true)]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
  const tB=getCD(copRateBudget,idxs),tE=getCD(copRateEconomy,idxs),tM=getCD(copRateMid,idxs),tU=getCD(copRateUpscale,idxs),tL=getCD(copRateLuxury,idxs);
  mkChart('ch-rate-tier',{type:'line',data:{labels:tB.labels,datasets:[lineDS('Budget',tB.data,C[1]),lineDS('Economy',tE.data,C[2]),lineDS('Midscale',tM.data,C[0]),lineDS('Upscale',tU.data,C[4]),lineDS('Luxury',tL.data,C[3])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
  const rb1=getCD(copRateB1,idxs),rb2=getCD(copRateB2,idxs),rb3=getCD(copRateB3,idxs),rb4=getCD(copRateB4,idxs);
  mkChart('ch-rate-bed',{type:'line',data:{labels:rb1.labels,datasets:[lineDS('1 Quarto',rb1.data,C[0]),lineDS('2 Quartos',rb2.data,C[1]),lineDS('3 Quartos',rb3.data,C[2]),lineDS('4 Quartos',rb4.data,C[3])]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.label+': '+fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45}}),y:ax()}}});
  // Daily history — NOT filtered by period state
  mkChart('ch-rate-daily',{type:'line',data:{labels:dRateDates,datasets:[lineDS('Tarifa Diária (R$)',dRateVals,C[5],true)]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>'Tarifa: '+fmtBRL(ctx.raw,0)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{x:ax({ticks:{maxRotation:45,maxTicksLimit:14}}),y:ax()}}});
  // Future forecast
  mkChart('ch-rate-future',{type:'line',data:{labels:futDates,datasets:[lineDS('Tarifa Prevista (R$)',futRateVals,C[0],true,'y'),lineDS('Anúncios Reservados',futListings,C[2],false,'y1')]},options:{responsive:true,maintainAspectRatio:false,plugins:{tooltip:{...TTP,callbacks:{label:ctx=>ctx.dataset.yAxisID==='y1'?'Anúncios: '+fmtNum(ctx.raw):'Tarifa: '+fmtBRL(ctx.raw,2)}},legend:{position:'bottom',labels:{color:'#94a3b8'}}},scales:{
    x:ax({ticks:{maxRotation:45,maxTicksLimit:18}}),
    y:{...ax(),position:'left',title:{display:true,text:'Tarifa (R$)',color:'#64748b'}},
    y1:{...ax(),position:'right',grid:{drawOnChartArea:false},title:{display:true,text:'Anúncios',color:'#64748b'}},
  }}});
}

function renderSeasonality(){
  const YEARS=['2023','2024','2025','2026'];
  const map=(arr)=>{
    const m={};
    monthlyKeys.forEach((k,i)=>{const[y,mo]=k.split('-');if(!m[y])m[y]={};m[y][mo]=arr[i];});
    return m;
  };
  function buildTbl(id,arr,fmtFn){
    const tbl=document.getElementById(id);if(!tbl)return;
    const M=map(arr);
    let h='<thead><tr><th>Mês</th>';
    YEARS.forEach(y=>h+=`<th>${y}</th>`);
    h+='<th>Δ 24/23</th><th>Δ 25/24</th><th>Δ 26/25</th></tr></thead><tbody>';
    for(let m=1;m<=12;m++){
      const mm=String(m).padStart(2,'0');
      const vals=YEARS.map(y=>M[y]&&M[y][mm]!=null?M[y][mm]:null);
      const deltas=[0,1,2].map(k=>vals[k]!=null&&vals[k+1]!=null?deltaPct(vals[k],vals[k+1]):null);
      h+=`<tr><td>${MNAMES_PT[m-1]}</td>`;
      vals.forEach(v=>h+=`<td>${v!=null?fmtFn(v):'–'}</td>`);
      deltas.forEach(d=>{
        if(d==null){h+='<td class="dn0">–</td>';return;}
        const cls=d>0.05?'dp':d<-0.05?'dn':'dn0';
        h+=`<td><span class="${cls}">${d>=0?'+':''}${d.toFixed(1)}%</span></td>`;
      });
      h+='</tr>';
    }
    h+='</tbody>';
    tbl.innerHTML=h;
  }
  buildTbl('tbl-occ',mOcc,fmtPct);
  buildTbl('tbl-rev',mRev,v=>fmtBRL(v,0));
  buildTbl('tbl-coprev',copRevAvg,v=>fmtBRL(v,0));
  buildTbl('tbl-coprate',copRateAvg,v=>fmtBRL(v,0));

  // ── Tabela Comparativa Hotelaria vs STR (por região selecionada) ──────────
  (function(){
    const reg=REGIONS[activeRegion];
    const titleEl=document.getElementById('tbl-hotelvsstr-title');
    if(titleEl)titleEl.textContent='Comparativo de Ocupação — Hotelaria Formal (%) vs STR AirDNA (%) · '+reg.label;
    const YEARS=['2023','2024','2025','2026'];
    const mapArr=(arr)=>{
      const m={};
      monthlyKeys.forEach((k,i)=>{const[y,mo]=k.split('-');if(!m[y])m[y]={};if(arr[i]!=null)m[y][mo]=arr[i];});
      return m;
    };
    const mH=mapArr(reg.hotel), mS=mapArr(reg.str);
    const tbl=document.getElementById('tbl-hotelvsstr');
    if(!tbl)return;
    let h='<thead><tr><th>Mês</th>';
    YEARS.forEach(y=>{
      h+=`<th colspan="2" style="text-align:center;border-left:1px solid #2d3148">${y}</th>`;
    });
    h+='</tr><tr><th></th>';
    YEARS.forEach(()=>h+='<th style="border-left:1px solid #2d3148">🏨 Hotel</th><th>🏠 STR</th>');
    h+='</tr></thead><tbody>';
    for(let m=1;m<=12;m++){
      const mm=String(m).padStart(2,'0');
      h+=`<tr><td>${MNAMES_PT[m-1]}</td>`;
      YEARS.forEach(y=>{
        const hv=mH[y]&&mH[y][mm]!=null?mH[y][mm]:null;
        const sv=mS[y]&&mS[y][mm]!=null?mS[y][mm]:null;
        let diff='', diffCls='dn0';
        if(hv!=null&&sv!=null){
          const d=sv-hv;
          diffCls=d>0?'dp':d<0?'dn':'dn0';
          diff=` <span class="${diffCls}" style="font-size:10px">(${d>=0?'+':''}${d.toFixed(1)})</span>`;
        }
        h+=`<td style="border-left:1px solid #1e2235">${hv!=null?fmtPct(hv):'–'}</td>`;
        h+=`<td>${sv!=null?fmtPct(sv)+diff:'–'}</td>`;
      });
      h+='</tr>';
    }
    // Linha de média anual
    h+='<tr style="border-top:2px solid #2d3148"><td style="font-weight:600;color:#e2e8f0">Média Anual</td>';
    YEARS.forEach(y=>{
      const hvArr=Object.values(mH[y]||{});
      const svArr=Object.values(mS[y]||{});
      const hAvg=hvArr.length?avg(hvArr):null;
      const sAvg=svArr.length?avg(svArr):null;
      let diff='', diffCls='dn0';
      if(hAvg!=null&&sAvg!=null){
        const d=sAvg-hAvg;
        diffCls=d>0?'dp':d<0?'dn':'dn0';
        diff=` <span class="${diffCls}" style="font-size:10px">(${d>=0?'+':''}${d.toFixed(1)})</span>`;
      }
      h+=`<td style="border-left:1px solid #1e2235;font-weight:600">${hAvg!=null?fmtPct(hAvg):'–'}</td>`;
      h+=`<td style="font-weight:600">${sAvg!=null?fmtPct(sAvg)+diff:'–'}</td>`;
    });
    h+='</tr></tbody>';
    tbl.innerHTML=h;
  })();
}

// ══════════════════ REGION FILTER ══════════════════
const REGION_BTNS=[
  {key:'cidade', label:'🌐 Rio de Janeiro'},
  {key:'copa',   label:'🏖️ Leme / Copa'},
  {key:'ipanema',label:'🌊 Ipanema / Leblon'},
  {key:'flamengo',label:'🌿 Flamengo / Botafogo'},
  {key:'barra',  label:'🏙️ Barra / Recreio'},
  {key:'centro', label:'🏛️ Centro'},
];
function buildRegionBar(){
  ['region-bar-occ','region-bar-sea'].forEach(cid=>{
    const el=document.getElementById(cid); if(!el)return;
    REGION_BTNS.forEach(({key,label})=>{
      const btn=document.createElement('button');
      btn.className='chip region-chip'+(key===activeRegion?' active':'');
      btn.textContent=label; btn.dataset.region=key;
      btn.addEventListener('click',()=>{
        activeRegion=key;
        document.querySelectorAll('.region-chip').forEach(b=>b.classList.toggle('active',b.dataset.region===activeRegion));
        renderOccupancy();
        renderSeasonality();
      });
      el.appendChild(btn);
    });
  });
}

// ══════════════════ FILTER UI ══════════════════
function buildDropdowns(){
  const sEl=document.getElementById('selStart'), eEl=document.getElementById('selEnd');
  monthlyKeys.forEach(k=>{
    [sEl,eEl].forEach(el=>{const o=new Option(fmtM(k),k);el.appendChild(o);});
  });
  sEl.value=state.startMonth; eEl.value=state.endMonth;
  sEl.addEventListener('change',()=>{state.startMonth=sEl.value;state.activePreset='';updateChips();renderAll();});
  eEl.addEventListener('change',()=>{state.endMonth=eEl.value;state.activePreset='';updateChips();renderAll();});
}
function buildChips(){
  const bar=document.getElementById('presetsBar');
  Object.entries(PRESETS).forEach(([k,p])=>{
    const btn=document.createElement('button');
    btn.className='chip'+(k===state.activePreset?' active':'');
    btn.textContent=p.label; btn.dataset.key=k;
    btn.addEventListener('click',()=>{
      state={...state,startMonth:p.start,endMonth:p.end,season:p.season,activePreset:k};
      document.getElementById('selStart').value=state.startMonth;
      document.getElementById('selEnd').value=state.endMonth;
      updateChips(); renderAll();
    });
    bar.appendChild(btn);
  });
}
function updateChips(){document.querySelectorAll('.chip').forEach(b=>b.classList.toggle('active',b.dataset.key===state.activePreset));}
function buildGran(){
  document.querySelectorAll('.gran-btn').forEach(b=>{
    b.addEventListener('click',()=>{
      state.gran=b.dataset.g;
      document.querySelectorAll('.gran-btn').forEach(x=>x.classList.toggle('active',x.dataset.g===state.gran));
      renderAll();
    });
  });
}

// ══════════════════ TABS ══════════════════
let activeTab='overview';
const tabRenderers={overview:renderOverview,listings:renderListings,occupancy:renderOccupancy,revenue:renderRevenue,rates:renderRates,seasonality:renderSeasonality};
function buildTabs(){
  document.querySelectorAll('.tab-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      activeTab=btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b=>b.classList.toggle('active',b.dataset.tab===activeTab));
      document.querySelectorAll('.tab-pane').forEach(p=>p.classList.toggle('active',p.id==='tab-'+activeTab));
      (tabRenderers[activeTab]||function(){})();
    });
  });
}
function renderAll(){Object.values(tabRenderers).forEach(fn=>fn());}

// ══════════════════ INIT ══════════════════
buildDropdowns();
buildChips();
buildGran();
buildRegionBar();
buildTabs();
renderAll();
</script>
</body>
</html>
