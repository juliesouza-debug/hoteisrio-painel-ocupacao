              75.65,72.32,66.86,54.38,57.55,59.45,64.93,63.78,69.54,69.96,73.41,74.82,
              85.61,83.68,83.62,75.33,67.37,59.34,70.60,66.33,76.44,80.56,72.66,74.21,
