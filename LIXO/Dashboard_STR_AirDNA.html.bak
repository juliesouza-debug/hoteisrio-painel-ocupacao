const hCentro=[55.29,58.04,55.01,68.88,60.86,68.32,81.98,60.32,
               65.61,69.27,55.53,58.23,65.06,59.16,56.86,61.81,70.16,73.21,75.07,62.07,
               69.94,75.04,75.56,67.20,68.95,62.71,60.84,64.50,70.61,70.14,71.62,65.64,
