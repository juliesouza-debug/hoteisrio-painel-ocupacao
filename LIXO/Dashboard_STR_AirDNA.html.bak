// Copacabana Rates
const copRateAvg=[312,324,329,327,338,346,362,432,474,503,402,403,371,365,364,364,460,382,425,486,520,503,519,461,420,391,380,367,370,384,419,498,555,633,469,443];
const copRateBudget=[193,208,214,208,219,231,226,264,281,285,239,231,241,239,251,243,301,260,268,293,306,277,282,263,256,250,243,232,229,250,257,288,332,358,291,281];
